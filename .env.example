# Copy this file to .env and fill in your values.
# The deploy.sh script reads these to generate the final YAML files.

# -----------------------------------------------------------------------------
# REQUIRED — entity-ID substitutions
# -----------------------------------------------------------------------------

# go-eCharger serial number (found in entity IDs like sensor.goe_XXXXXX_nrg_11)
GOE_SERIAL=123456

# Tibber home identifier (the slug in entity IDs like sensor.electricity_price_XXXXX)
TIBBER_HOME=musterstrasse_1

# iPhone notify service name (the part after notify.mobile_app_)
IPHONE_DEVICE=my_iphone

# Tibber Graph camera entity (if using tibber_graph integration)
TIBBER_GRAPH_CAMERA=camera.tibber_graph_musterstrasse_1

# -----------------------------------------------------------------------------
# OPTIONAL — config volume auto-mount (macOS only)
# -----------------------------------------------------------------------------
# If set, deploy.sh will auto-mount the SMB share when HA_CONFIG_MOUNT is not
# already mounted. macOS uses the Keychain for the password, so you must have
# mounted the share manually in Finder once with "Remember password in my
# Keychain" checked. Otherwise an authentication dialog will appear.

# Default target mount point (can be overridden via positional arg to deploy.sh)
HA_CONFIG_MOUNT=/Volumes/config

# SMB URL to auto-mount when HA_CONFIG_MOUNT is not mounted.
# Leave empty to disable auto-mount (then mount manually in Finder).
#HA_CONFIG_SMB_URL=smb://user@192.168.1.10/config

# -----------------------------------------------------------------------------
# OPTIONAL — auto-push dashboard via HA WebSocket API
# -----------------------------------------------------------------------------
# If both HA_URL and HA_TOKEN are set, deploy.sh will push the rendered
# dashboard config to HA via tools/ha_update_dashboard.py, eliminating the
# "paste raw YAML" step. Requires `uv` to be installed.
# Create a long-lived access token at:
#   Profile → Security → Long-Lived Access Tokens

#HA_URL=http://192.168.1.10:8123
#HA_TOKEN=eyJhbGciOi...your.long.lived.token...

# URL path of the target dashboard (default: ev-charging).
# Create the dashboard once via the HA UI — the tool only updates it.
#HA_DASHBOARD_URL_PATH=ev-charging
